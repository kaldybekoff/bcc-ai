# Скопируйте в backend/.env и впишите реальные значения. НЕ коммитьте .env!

# OpenAI API Key — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Модель генерации ответов (gpt-4o — точнее/глубже, gpt-4o-mini — дешевле)
OPENAI_MODEL=gpt-4o

# Модель эмбеддингов для семантического поиска по базе знаний
EMBED_MODEL=text-embedding-3-small

# CORS — URL фронтенда через запятую
CORS_ORIGINS=http://localhost:3000,https://bcc-ai.vercel.app

# Опционально:
# MAX_CONTEXT_CHARS=30000      # бюджет символов контекста на запрос
# MAX_OUTPUT_TOKENS=3000       # максимум токенов в ответе
# MAX_HISTORY_MESSAGES=8       # сколько предыдущих сообщений диалога учитывать
