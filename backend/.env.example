# Скопируйте в backend/.env и впишите реальные значения. НЕ коммитьте .env!

# Google Gemini API Key — https://aistudio.google.com/ → Get API Key
GEMINI_API_KEY=AIza...

# Окружение: development | production
ENVIRONMENT=development

# CORS — URL фронтенда через запятую
CORS_ORIGINS=http://localhost:3000,https://bcc-assistant.vercel.app

# ChromaDB (опционально)
CHROMA_PATH=./chroma_db
CHROMA_COLLECTION=bcc_knowledge
