islider.min.js"></script>
<script src=3D"https://cdnjs.cloudflare.com/ajax/libs/wnumb/1.2.0/wNumb.min=
.js"></script>
<script>
document.addEventListener("DOMContentLoaded", function() {
  const allowedPages =3D ['229255959', '174299271', '174299271'];
  const currentUrl =3D window.location.href;
  const isAllowedPage =3D allowedPages.some(pageId =3D> currentUrl.includes=
(`pageId=3D${pageId}`));

  if (isAllowedPage) {
    document.getElementById('calculator').style.display =3D 'block';

    var principalSlider =3D document.getElementById('principalSlider');
    var downpaymentSlider =3D document.getElementById('downpaymentSlider');
    var rateSlider =3D document.getElementById('rateSlider');
    var monthsSlider =3D document.getElementById('monthsSlider');
    var loanAmountElement =3D document.getElementById('loanAmount');
    var insuranceCheckbox =3D document.getElementById('insurance');
    var userHasModifiedDownpayment =3D false;

    noUiSlider.create(principalSlider, {
      start: [50000],
      connect: [true, false],
      range: {
        'min': 50000,
        'max': 45000000
      },
      step: 50000,
      format: wNumb({
        decimals: 0,
        thousand: ' '
      })
    });

    noUiSlider.create(downpaymentSlider, {
      start: [10000],
      connect: [true, false],
      range: {
        'min': 0,
        'max': 45000000
      },
      step: 50000,
      format: wNumb({
        decimals: 0,
        thousand: ' ',
        suffix: ' =E2=82=B8'
      })
    });

    noUiSlider.create(rateSlider, {
      start: [10],
      connect: [true, false],
      range: {
        'min': 1,
        'max': 30
      },
      step: 0.1,
      format: wNumb({
        decimals: 1
      })
    });

    noUiSlider.create(monthsSlider, {
      start: [12],
      connect: [true, false],
      range: {
        'min': 6,
        'max': 84
      },
      step: 1,
      format: wNumb({
        decimals: 0
      })
    });

    function syncSliderWithInput(slider, input, callback) {
      var userInput =3D false;

      slider.noUiSlider.on('update', function(values, handle) {
        if (!userInput) {
          input.value =3D formatCurrency(values[handle]);
          if (callback) callback();=20
          calculate();
        }
      });

      input.addEventListener('input', function() {
        userInput =3D true;
        this.value =3D formatCurrency(this.value.replace(/\s/g, ''));
      });

      input.addEventListener('change', function() {
        var value =3D parseFloat(this.value.replace(/\s/g, '')) || 0;
        slider.noUiSlider.set(value);
        userInput =3D false;
        calculate();
      });
    }

    syncSliderWithInput(principalSlider, document.getElementById('principal=
'), function() {
      if (!userHasModifiedDownpayment) {
        updateDownpayment(parseFloat(document.getElementById('principal').v=
alue.replace(/\s/g, '')) || 0);
      }
    });
    syncSliderWithInput(downpaymentSlider, document.getElementById('downpay=
ment'));
    syncSliderWithInput(rateSlider, document.getElementById('rate'));
    syncSliderWithInput(monthsSlider, document.getElementById('months'));

    function formatCurrency(value) {
      return value.toString().replace(/\B(?=3D(\d{3})+(?!\d))/g, " ");
    }

    window.setMonths =3D function(months, button) {
      monthsSlider.noUiSlider.set(months);
      document.getElementById('months').value =3D months;

      var buttons =3D document.querySelectorAll('.months-buttons button');
      buttons.forEach(function(btn) {
        btn.classList.remove('active');
      });
      button.classList.add('active');

      calculate();
    };

    function updateDownpayment(principal) {
      var downpayment =3D principal * 0.1;
      document.getElementById('downpayment').value =3D formatCurrency(downp=
ayment);
      downpaymentSlider.noUiSlider.set(downpayment);
    }

    document.getElementById('downpayment').addEventListener('input', functi=
on() {
      userHasModifiedDownpayment =3D true;
      this.value =3D formatCurrency(this.value.replace(/\s/g, ''));
    });

    document.getElementById('principal').addEventListener('change', functio=
n() {
      userHasModifiedDownpayment =3D false; =20
      updateDownpayment(parseFloat(this.value.replace(/\s/g, '')));
      calculate();
    });

    function calculate() {
      var principal =3D parseFloat(document.getElementById('principal').val=
ue.replace(/\s/g, '')) || 0;
      var downpayment =3D parseFloat(document.getElementById('downpayment')=
.value.replace(/\s/g, '')) || 0;
      var rate =3D parseFloat(document.getElementById('rate').value) || 0;
      var months =3D parseInt(document.getElementById('months').value) || 0=
;
      var monthlyRate =3D rate / 12 / 100;
      var loanAmount =3D principal - downpayment;

      if (insuranceCheckbox.checked) {
        var insuranceMonths =3D Math.min(months, 60); =20
        var insurance =3D loanAmount * (0.02 * insuranceMonths / 12);
        loanAmount +=3D insurance;
      }

      loanAmountElement.textContent =3D formatCurrency(Math.round(loanAmoun=
t)) + ' =E2=82=B8';

      if (loanAmount > 0 && rate > 0 && months > 0) {
        var monthlyPayment =3D loanAmount * monthlyRate / (1 - Math.pow(1 +=
 monthlyRate, -months));
        var totalPayment =3D monthlyPayment * months;
        var overpayment =3D totalPayment - loanAmount;

        document.getElementById('monthlyPayment').textContent =3D formatCur=
rency(Math.round(monthlyPayment)) + ' =E2=82=B8';
        document.getElementById('totalPayment').textContent =3D formatCurre=
ncy(Math.round(totalPayment)) + ' =E2=82=B8';
        document.getElementById('overpayment').textContent =3D formatCurren=
cy(Math.round(overpayment)) + ' =E2=82=B8';
      } else {
        document.getElementById('monthlyPayment').textContent =3D '0 =E2=82=
=B8';
        document.getElementById('totalPayment').textContent =3D '0 =E2=82=
=B8';
        document.getElementById('overpayment').textContent =3D '0 =E2=82=B8=
';
      }
    }

    insuranceCheckbox.addEventListener('change', calculate);

    calculate();=20
  }
});
</script>
