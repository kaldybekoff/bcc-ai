            color: #333;
            margin: 0 auto;
          }

          #unique-insurance-calculator h1 {
            text-align: center;
            font-size: 20px;
            color: #444;
            margin-bottom: 15px;
            margin-top: 5px;
            font-weight: bold;
          }

          #unique-insurance-calculator .unique-input-group {
            display: flex;
            flex-direction: column;
            gap: 8px;
          }

          #unique-insurance-calculator .unique-input-group label {
            font-weight: 600;
            color: #555;
            font-size: 13px;
          }

          #unique-insurance-calculator .unique-input-group input[type=3D"te=
xt"],=20
          #unique-insurance-calculator .unique-input-group input[type=3D"da=
te"],=20
          #unique-insurance-calculator .unique-input-group input[type=3D"nu=
mber"] {
            width: 100%;
            padding: 10px;
            border-radius: 10px;
            border: 1px solid #ccc;
            background: rgba(255, 255, 255, 0.7);
            box-shadow: inset 1px 1px 4px rgba(0, 0, 0, 0.1), inset -1px -1=
px 4px rgba(255, 255, 255, 0.8);
            font-size: 14px;
            outline: none;
            transition: box-shadow 0.3s ease, background 0.3s ease;
          }

          #unique-insurance-calculator .unique-input-group input[type=3D"te=
xt"]:focus,=20
          #unique-insurance-calculator .unique-input-group input[type=3D"da=
te"]:focus,=20
          #unique-insurance-calculator .unique-input-group input[type=3D"nu=
mber"]:focus {
            box-shadow: inset 2px 2px 5px rgba(0, 0, 0, 0.1), inset -2px -2=
px 5px rgba(255, 255, 255, 0.9);
            background: rgba(255, 255, 255, 0.85);
          }

          #unique-insurance-calculator button {
            width: 100%;
            padding: 12px;
            text-align: center;
            background: linear-gradient(135deg, #4a90e2, #357ab8);
            color: white;
            border: none;
            border-radius: 10px;
            font-size: 14px;
            font-weight: bold;
            cursor: pointer;
            transition: background 0.3s ease, transform 0.2s ease, box-shad=
ow 0.2s ease;
            box-shadow: 3px 3px 10px rgba(0, 0, 0, 0.1), -3px -3px 10px rgb=
a(255, 255, 255, 0.9);
          }

          #unique-insurance-calculator button:hover {
            background: linear-gradient(135deg, #357ab8, #4a90e2);
            transform: translateY(-2px);
            box-shadow: 4px 4px 12px rgba(0, 0, 0, 0.15), -4px -4px 12px rg=
ba(255, 255, 255, 1);
          }

          #unique-insurance-calculator .unique-result {
            margin-top: 15px;
            padding: 10px;
