      `;

      container.innerHTML =3D calculatorStyles + calculatorHTML;

      document.getElementById('unique-premium').addEventListener('input', f=
unction() {
        this.value =3D this.value.replace(/\D/g, '').replace(/\B(?=3D(\d{3}=
)+(?!\d))/g, ' ');
      });

      function calculateDays(startDate, endDate) {
        const timeDifference =3D endDate - startDate;
        return Math.ceil(timeDifference / (1000 * 60 * 60 * 24) + 1);
      }

      function autoCalculateUniqueDates() {
        const startDate =3D new Date(document.getElementById('unique-startD=
ate').value);
        const endDate =3D new Date(document.getElementById('unique-endDate'=
).value);

        if (startDate && endDate && startDate <=3D endDate) {
          const totalDays =3D calculateDays(startDate, endDate);
          document.getElementById('unique-contractDays').value =3D totalDay=
s;
          autoCalculateUniqueRemainingDays();
        } else {
          document.getElementById('unique-contractDays').value =3D 0;
          document.getElementById('unique-remainingDays').value =3D 0;
        }
      }

      function autoCalculateUniqueRemainingDays() {
        const terminationDate =3D new Date(document.getElementById('unique-=
terminationDate').value);
        const endDate =3D new Date(document.getElementById('unique-endDate'=
).value);

        if (terminationDate && endDate && terminationDate <=3D endDate) {
          const remainingDays =3D calculateDays(terminationDate, endDate) -=
 1;
          document.getElementById('unique-remainingDays').value =3D remaini=
ngDays;
        } else {
          document.getElementById('unique-remainingDays').value =3D 0;
        }
      }

      document.getElementById('unique-calculate-button').addEventListener('=
click', function() {
        const premium =3D parseFloat(document.getElementById('unique-premiu=
m').value.replace(/\s/g, '')) || 0;
        const totalDays =3D parseFloat(document.getElementById('unique-cont=
ractDays').value);
        const remainingDays =3D parseFloat(document.getElementById('unique-=
remainingDays').value);

        const deductionPercent =3D 10;
        const deductionAmount =3D (deductionPercent / 100) * premium;

        const refundableAmount =3D ((premium - deductionAmount) / totalDays=
) * remainingDays;
        const formattedRefund =3D Math.round(refundableAmount).toString().r=
eplace(/\B(?=3D(\d{3})+(?!\d))/g, ' ');

        document.getElementById('unique-result').innerHTML =3D `<div>=D0=A1=
=D1=83=D0=BC=D0=BC=D0=B0 =D0=BA =D0=B2=D0=BE=D0=B7=D0=B2=D1=80=D0=B0=D1=82=
=D1=83: ${formattedRefund} =E2=82=B8</div>`;
      });
    }
  }
</script>
