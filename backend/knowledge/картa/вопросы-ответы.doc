=96', '"': '=D0=AD',
    'Z': '=D0=AF', 'X': '=D0=A7', 'C': '=D0=A1', 'V': '=D0=9C', 'B': '=D0=
=98', 'N': '=D0=A2', 'M': '=D0=AC', '<': '=D0=91', '>': '=D0=AE', '?': ',',
    '~': '=D0=81',
    '@': '"', '#': '=E2=84=96', '$': ';', '^': ':', '&': '?'=20
};

function transliterateEngToRu(text) {
    return text.split('').map(char =3D> engToRuLayout[char] || char).join('=
');
}

function searchText() {
    var input =3D document.getElementById('searchInput');
    var originalFilter =3D input.value.trim().replace(/\s+/g, ' ');
    var resultsList =3D document.getElementById('results');
    resultsList.innerHTML =3D '';

    if (!originalFilter) return;

    var filterUpperCase =3D originalFilter.toUpperCase();
    var transliteratedFilter =3D transliterateEngToRu(originalFilter);
    var transliteratedFilterUpperCase =3D transliteratedFilter.toUpperCase(=
);

    // If transliteration resulted in the same string (e.g., user typed in =
Russian or mixed),
    // we don't need to search for it separately unless it's different from=
 the original.
    var filtersToTry =3D [filterUpperCase];
    if (transliteratedFilterUpperCase !=3D=3D filterUpperCase) {
        filtersToTry.push(transliteratedFilterUpperCase);
    }


    var textNodes =3D [];
    function getTextNodes(element) {
        if (!element) return;

        element.childNodes.forEach(function(node) {
            if (node.nodeType =3D=3D=3D 3 && node.nodeValue.trim() !=3D=3D =
'') { // Text node
                textNodes.push(node);
            } else if (node.nodeType =3D=3D=3D 1 && // Element node
                       node.nodeName !=3D=3D 'SCRIPT' &&
                       node.nodeName !=3D=3D 'STYLE' &&
                       node.offsetParent !=3D=3D null) { // Visible element
                getTextNodes(node);
            }
        });
    }

    var content =3D document.querySelector('#main-content');
    if (content) {
        getTextNodes(content);
    }

    var foundTexts =3D new Set();=20

    textNodes.forEach(function(node) {
        var nodeText =3D node.nodeValue;
        var normalizedNodeText =3D nodeText.trim().replace(/\s+/g, ' ').toU=
pperCase();

        for (const currentFilter of filtersToTry) {
            if (normalizedNodeText.includes(currentFilter)) {
                const displayText =3D nodeText.substring(0, 100) + (nodeTex=
t.length > 100 ? '...' : '');
                if (!foundTexts.has(displayText)) {=20
                    var li =3D document.createElement('li');
                    li.textContent =3D displayText;
                    li.onclick =3D function() { scrollToResult(node); };
                    resultsList.appendChild(li);
                    foundTexts.add(displayText);=20
                }
                break;=20
            }
        }
    });
}

function scrollToResult(node) {
    var element =3D node.parentNode; // Get the parent element to scroll to=
 and highlight
    element.scrollIntoView({ behavior: 'smooth', block: 'center' });

    // Highlight the content of the parent element
    // This is a simple highlight, for more complex scenarios you might nee=
d to wrap the found text in a span
    var range =3D document.createRange();
    range.selectNodeContents(element);=20
    var selection =3D window.getSelection();
    selection.removeAllRanges();
    selection.addRange(range);
}
