id #ddd; }
        #results li:hover { background-color: #f5f5f5; }
    </style><input type=3D"text" id=3D"searchInput" placeholder=3D"=D0=9F=
=D0=BE=D0=B8=D1=81=D0=BA" oninput=3D"searchText()">
<ul id=3D"results"></ul>
<script>
function searchText() {
    var input =3D document.getElementById('searchInput');
    var filter =3D input.value.toUpperCase();
    var results =3D document.getElementById('results');
    results.innerHTML =3D '';=20

    if (!filter) return;=20

 =20
    function getTextNodes(element) {
        element.childNodes.forEach(function(node) {
            if (node.nodeType =3D=3D=3D 3 && node.nodeValue.trim() !=3D=3D =
'') {
                textNodes.push(node);
            } else if (node.nodeType =3D=3D=3D 1 && node.nodeName !=3D=3D '=
SCRIPT' && node.nodeName !=3D=3D 'STYLE' && node.offsetParent !=3D=3D null)=
 {
                getTextNodes(node);
            }
        });
    }

    var textNodes =3D [];
    getTextNodes(document.body);=20

 =20
    textNodes.forEach(function(node) {
        var nodeText =3D node.nodeValue;
        if (nodeText.toUpperCase().includes(filter)) {
            var li =3D document.createElement('li');
            li.textContent =3D nodeText.substr(0, 100) + '...';=20
            li.onclick =3D function() { scrollToResult(node); };
            results.appendChild(li);
        }
    });
}

function scrollToResult(node) {
    var element =3D node.parentNode;
    element.scrollIntoView({ behavior: 'smooth', block: 'center' });

=20
    var range =3D document.createRange();
    range.selectNodeContents(element);
    var selection =3D window.getSelection();
    selection.removeAllRanges();
    selection.addRange(range);
}
</script>
