<script>
const header =3D $("#header");
const fixedHeader =3D "fixed-header";
$(window).on("scroll", () =3D> {=20
     if(window.pageYOffset > header.outerHeight()){
          if(!header.hasClass(fixedHeader)){
               header.addClass(fixedHeader);=20
          }
     } else {=20
          header.removeClass(fixedHeader);=20
     }
});
</script>
