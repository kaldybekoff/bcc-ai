    #calculator .calculator-box {
      background: #fff;
      padding: 40px;
      border-radius: 20px;
      box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
      flex: 1;
      position: relative;
    }

    #calculator .input-group {
      margin-bottom: 20px;
      display: flex;
      flex-direction: column;
      width: 100%;
    }

    #calculator .input-group label {
      margin-bottom: 8px;
      color: #333;
      font-size: 16px;
      font-weight: 600;
    }

    #calculator .input-group input[type=3Dtext],
    #calculator .input-group input[type=3Dnumber] {
      padding: 14px;
      border: 2px solid #d0e0e0;
      border-radius: 10px;
      font-size: 22px;
      font-weight: 500;
      color: #333;
      box-sizing: border-box;
      transition: border-color 0.3s ease, box-shadow 0.3s ease;
      background-color: #f9f9f9;
    }

    #calculator .input-group input[type=3Dtext]:focus,
    #calculator .input-group input[type=3Dnumber]:focus {
      border-color: #3498db;
      box-shadow: 0 0 8px rgba(52, 152, 219, 0.4);
      background-color: #fff;
    }

    #calculator .input-group .range-slider {
      margin-top: 10px;
    }

    #calculator .input-group .range-scale {
      display: flex;
      justify-content: space-between;
      font-size: 12px;
      color: #999;
      margin-top: 8px;
    }

    #calculator .noUi-horizontal {
      height: 8px !important;
      background: linear-gradient(90deg, #3498db, #27ae60) !important;
      border-radius: 4px !important;
    }

    #calculator .noUi-connect {
      height: 8px !important;
      background: linear-gradient(90deg, #27ae60, #1abc9c) !important;
      border-radius: 4px !important;
    }

    #calculator .noUi-handle {
      width: 20px !important;
      height: 20px !important;
      border-radius: 50% !important;
      background: #3498db !important;
      border: 2px solid #fff !important;
      top: -8px !important;
      transition: background-color 0.3s ease;
    }

    #calculator .noUi-handle:hover {
      background-color: #1abc9c !important;
    }

    #calculator .button {
      width: 100%;
      background: linear-gradient(135deg, #27ae60, #1abc9c);
      color: white;
      padding: 15px;
      border: none;
      border-radius: 10px;
      cursor: pointer;
      font-size: 18px;
      font-weight: 600;
      transition: background 0.3s ease, transform 0.2s ease;
      margin-top: 10px;
      box-shadow: 0 8px 20px rgba(39, 174, 96, 0.2);
    }

    #calculator .button:hover {
      background: linear-gradient(135deg, #1abc9c, #16a085);
      transform: translateY(-2px);
      box-shadow: 0 10px 25px rgba(39, 174, 96, 0.3);
    }

    #calculator .results-container {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding-top: 15px;
