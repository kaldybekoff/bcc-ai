<script src=3D"https://cdnjs.cloudflare.com/ajax/libs/wnumb/1.2.0/wNumb.min=
.js"></script>
<script>
document.addEventListener("DOMContentLoaded", function() {
  var principalSlider =3D document.getElementById('principalSlider');
  var downpaymentSlider =3D document.getElementById('downpaymentSlider');
  var rateSlider =3D document.getElementById('rateSlider');
  var monthsSlider =3D document.getElementById('monthsSlider');
  var downpaymentInput =3D document.getElementById('downpayment');
  var loanAmountElement =3D document.getElementById('loanAmount');

  noUiSlider.create(principalSlider, {
    start: [50000],=20
    connect: [true, false],
    range: {
      'min': 50000,=20
      'max': 100000000
    },
    step: 50000,
    format: wNumb({
      decimals: 0,
      thousand: ' '
    })
  });

  function updateDownpaymentSlider(principal) {
    downpaymentSlider.noUiSlider.updateOptions({
      range: {
        'min': 0,
        'max': principal
      },
      step: 10000,
      start: principal * 0.2,=20
    });
  }

  noUiSlider.create(downpaymentSlider, {
    start: [10000], // =D0=9D=D0=B0=D1=87=D0=B0=D0=BB=D1=8C=D0=BD=D0=BE=D0=
=B5 =D0=B7=D0=BD=D0=B0=D1=87=D0=B5=D0=BD=D0=B8=D0=B5 =D0=B1=D1=83=D0=B4=D0=
=B5=D1=82 =D0=BE=D0=B1=D0=BD=D0=BE=D0=B2=D0=BB=D1=8F=D1=82=D1=8C=D1=81=D1=
=8F
    connect: [true, false],
    range: {
      'min': 0,
      'max': 1000000=20
    },
    step: 10000,
    format: wNumb({
      decimals: 0,
      thousand: ' ',
      suffix: ' =E2=82=B8'
    })
  });

  noUiSlider.create(rateSlider, {
    start: [7],
    connect: [true, false],
    range: {
      'min': 1,
      'max': 50
    },
    step: 0.1,
    format: wNumb({
      decimals: 1
    })
  });

  noUiSlider.create(monthsSlider, {
    start: [12],
    connect: [true, false],
    range: {
      'min': 6,
      'max': 300
    },
    step: 1,
    format: wNumb({
      decimals: 0
    })
  });

  function syncSliderWithInput(slider, input) {
    var userInput =3D false;

    slider.noUiSlider.on('update', function(values, handle) {
      if (!userInput) {
        input.value =3D values[handle];
        calculate();
      }
    });

    input.addEventListener('input', function() {
      userInput =3D true;
      this.value =3D formatCurrency(this.value.replace(/\s/g, ''));
    });

    input.addEventListener('change', function() {
      var value =3D parseFloat(this.value.replace(/\s/g, '')) || 0;
      slider.noUiSlider.set(value);
      userInput =3D false;
      calculate();
    });
  }

  syncSliderWithInput(principalSlider, document.getElementById('principal')=
);
  syncSliderWithInput(downpaymentSlider, document.getElementById('downpayme=
nt'));
  syncSliderWithInput(rateSlider, document.getElementById('rate'));
  syncSliderWithInput(monthsSlider, document.getElementById('months'));

  function calculate() {
    var principal =3D parseFloat(document.getElementById('principal').value=
.replace(/\s/g, '')) || 0;
    var downpayment =3D parseFloat(document.getElementById('downpayment').v=
alue.replace(/\s/g, '')) || 0;
    var rate =3D parseFloat(document.getElementById('rate').value) || 0;
    var months =3D parseInt(document.getElementById('months').value) || 0;
    var monthlyRate =3D rate / 12 / 100;
    var loanAmount =3D principal - downpayment;

    loanAmountElement.textContent =3D formatCurrency(Math.round(loanAmount)=
) + ' =E2=82=B8';

    if (loanAmount > 0 && rate > 0 && months > 0) {
      var monthlyPayment =3D loanAmount * monthlyRate / (1 - Math.pow(1 + m=
onthlyRate, -months));
      var totalPayment =3D monthlyPayment * months;
      var overpayment =3D totalPayment - loanAmount;

      document.getElementById('monthlyPayment').textContent =3D formatCurre=
ncy(Math.round(monthlyPayment)) + ' =E2=82=B8';
      document.getElementById('totalPayment').textContent =3D formatCurrenc=
y(Math.round(totalPayment)) + ' =E2=82=B8';
      document.getElementById('overpayment').textContent =3D formatCurrency=
(Math.round(overpayment)) + ' =E2=82=B8';
    } else {
      document.getElementById('monthlyPayment').textContent =3D '0 =E2=82=
=B8';
      document.getElementById('totalPayment').textContent =3D '0 =E2=82=B8'=
;
      document.getElementById('overpayment').textContent =3D '0 =E2=82=B8';
    }
  }

  function formatCurrency(value) {
    return value.toString().replace(/\B(?=3D(\d{3})+(?!\d))/g, " ");
  }

  principalSlider.noUiSlider.on('update', function (values, handle) {
    var principal =3D parseFloat(values[handle].replace(/\s/g, ''));
    updateDownpaymentSlider(principal);
    calculate();
  });

  calculate();
});
</script>
</div>
</div>
</div>
</div>
