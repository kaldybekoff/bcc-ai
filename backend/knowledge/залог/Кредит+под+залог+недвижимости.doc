<script src=3D"https://cdnjs.cloudflare.com/ajax/libs/noUiSlider/15.6.1/nou=
islider.min.js"></script>
<script src=3D"https://cdnjs.cloudflare.com/ajax/libs/wnumb/1.2.0/wNumb.min=
.js"></script>
<script>
document.addEventListener("DOMContentLoaded", function() {
  var principalSlider =3D document.getElementById('principalSlider');
  var rateSlider =3D document.getElementById('rateSlider');
  var monthsSlider =3D document.getElementById('monthsSlider');

  noUiSlider.create(principalSlider, {
    start: [100000],
    connect: [true, false],
    range: {
      'min': 1000,
      'max': 100000000
    },
    step: 1000,
    format: wNumb({
      decimals: 0,
      thousand: ' '
    })
  });

  noUiSlider.create(rateSlider, {
    start: [14],
    connect: [true, false],
    range: {
      'min': 1,
      'max': 50
    },
    step: 0.1,
    format: wNumb({
      decimals: 1
    })
  });

  noUiSlider.create(monthsSlider, {
    start: [12],
    connect: [true, false],
    range: {
      'min': 6,
      'max': 300
    },
    step: 1,
    format: wNumb({
      decimals: 0
    })
  });

  function syncSliderWithInput(slider, input) {
    var isTyping =3D false;

    slider.noUiSlider.on('update', function(values, handle) {
      if (!isTyping) {
        input.value =3D values[handle];
        calculate();
      }
    });

    input.addEventListener('input', function() {
      isTyping =3D true;
      var value =3D parseFloat(this.value.replace(/\s/g, '')) || 0;
      slider.noUiSlider.set(value);
      isTyping =3D false;
      calculate();
    });

    input.addEventListener('change', function() {
      var value =3D parseFloat(this.value.replace(/\s/g, '')) || 0;
      slider.noUiSlider.set(value);
      calculate();
    });
  }

  syncSliderWithInput(principalSlider, document.getElementById('principal')=
);
  syncSliderWithInput(rateSlider, document.getElementById('rate'));
  syncSliderWithInput(monthsSlider, document.getElementById('months'));

  function calculate() {
    var principal =3D parseFloat(document.getElementById('principal').value=
.replace(/\s/g, '')) || 0;
    var rate =3D parseFloat(document.getElementById('rate').value) || 0;
    var months =3D parseInt(document.getElementById('months').value) || 0;
    var monthlyRate =3D rate / 12 / 100;

    if (principal > 0 && rate > 0 && months > 0) {
      var monthlyPayment =3D principal * monthlyRate / (1 - Math.pow(1 + mo=
nthlyRate, -months));
      var totalPayment =3D monthlyPayment * months;
      var overpayment =3D totalPayment - principal;

      document.getElementById('monthlyPayment').textContent =3D formatCurre=
ncy(Math.round(monthlyPayment)) + ' =E2=82=B8';
      document.getElementById('totalPayment').textContent =3D formatCurrenc=
y(Math.round(totalPayment)) + ' =E2=82=B8';
      document.getElementById('overpayment').textContent =3D formatCurrency=
(Math.round(overpayment)) + ' =E2=82=B8';
    } else {
      document.getElementById('monthlyPayment').textContent =3D '0 =E2=82=
=B8';
      document.getElementById('totalPayment').textContent =3D '0 =E2=82=B8'=
;
      document.getElementById('overpayment').textContent =3D '0 =E2=82=B8';
    }
  }

  function formatCurrency(value) {
    return value.toString().replace(/\B(?=3D(\d{3})+(?!\d))/g, " ");
  }

  // Initial calculation
  calculate();
});
</script>
