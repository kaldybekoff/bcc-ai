<style>
    #calculator {
      display: flex;
      max-width: 600px;
      margin: 0px 0 0 0; /* Adjust this margin to move the calculator up */
      font-family: 'Roboto', sans-serif;
      margin-top: -20px; /* Added margin-top to move the calculator up */
    }
    #calculator .calculator-box {
      background: white;
      padding: 15px;
      border-radius: 5px;
      flex: 1;
    }
    #calculator .input-group {
      margin-bottom: 0.5cm;
      display: flex;
      flex-direction: column;
      width: 100%;
    }
    #calculator .input-group label {
      margin-bottom: 5px;
      color: #6c757d;
      font-size: 13px;
      font-family: 'Roboto', sans-serif;
    }
    #calculator .input-group input[type=3Dtext],=20
    #calculator .input-group input[type=3Dnumber] {
      padding: 6px;
      border: 1px solid #ccc;
      border-radius: 4px;
      font-size: 18px;
      font-weight: 1000;
      color: #000;
      font-family: 'Roboto', sans-serif;
      margin-bottom: 15px;
      box-sizing: border-box;
    }
    #calculator .input-group .input-wrapper {
      display: flex;
      align-items: center;
    }
    #calculator .input-group .range-slider {
      width: 100%;
    }
    #calculator .input-group .range-scale {
      width: 100%;
      display: flex;
      justify-content: space-between;
      padding: 0;
      font-size: 10px;
      color: #6c757d;
      font-family: 'Roboto', sans-serif;
      margin-top: 6px;
    }
    #calculator .noUi-horizontal {
      height: 4px !important;
      background: linear-gradient(to right, #d4f1d4, #27ae60) !important;
      border-radius: 2px !important;
    }
    #calculator .noUi-connect {
      height: 4px !important;
      background: linear-gradient(to right, #d4f1d4, #27ae60) !important;
      border-radius: 2px !important;
    }
    #calculator .noUi-handle {
      width: 17px !important;
      height: 17px !important;
      border-radius: 50% !important;
      background: #27ae60 !important;
      border: 0px solid #fff !important;
      top: -7px !important;
      margin-left: -5px !important;
    }
    #calculator .noUi-target,=20
    #calculator .noUi-ltr,=20
    #calculator .noUi-horizontal,=20
    #calculator .noUi-handle {
      border-radius: 50% !important;
    }
    #calculator .noUi-handle:before,=20
    #calculator .noUi-handle:after {
      display: none !important;
    }
    #calculator .button {
      width: 100%;
      background-color: #27ae60;
      color: white;
      padding: 8px 18px;
      border: none;
      border-radius: 10px;
      cursor: pointer;
      font-size: 16px;
      font-family: 'Roboto', sans-serif;
      margin-top: 10px;
    }
    #calculator .results-container {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding-top: 15px;
      margin-left: 2cm; /* Added to shift results 2cm to the right */
    }
    #calculator .results {
      background-color: #fff;
      padding: 15px;
      border-radius: 10px;
      flex: 0 0 220px;
      margin-left: 10px;
    }
    #calculator .result-item {
      margin-bottom: 15px;
    }
    #calculator .result-label {
      color: #6c757d;
      font-size: 12px;
    }
    #calculator .result-value {
      color: #000;
      font-size: 18px;
      font-weight: 700;
    }
    #calculator .result-item:last-child {
      margin-bottom: 0;
    }
    #calculator .vertical-divider {
      border-left: 1px solid #bdc3c7;
      height: calc(100% - 4cm);
      margin-left: -20px;
      margin-top: 2cm;
      margin-bottom: 2cm;
    }
  </style>
